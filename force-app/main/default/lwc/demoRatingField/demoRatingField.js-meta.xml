<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Demo | Rating Field</masterLabel>
    <description>Demo runtime screen component used to smoke-test the CPE Toolkit. Configured via demoRatingFieldCpe, which passes a schema to c-pflow-organism-property-editor.</description>
    <targets>
        <target>lightning__FlowScreen</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__FlowScreen" configurationEditor="c-demo-rating-field-cpe">
            <property name="label" type="String" label="Screen Label" default="Rating" />
            <property name="maxStars" type="Integer" label="Max Stars" default="5" />
            <property name="required" type="Boolean" label="Required" default="false" />
            <property name="value" type="Integer" label="Value" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
